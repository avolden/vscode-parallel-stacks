{
  "name": "parallel-stacks",
  "displayName": "Parallel Stacks",
  "description": "Shows threads from a debugging session as a graph view",
  "publisher": "avolden",
  "repository": {
	"url": "https://github.com/avolden/vscode-parallel-stacks"
  },
  "version": "1.0.1",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
	"Other",
	"Debuggers"
  ],
  "activationEvents": [
	"onCommand:callstack-show",
	"onWebviewPanel:parallel-stacks",
	"onDebug"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "parallel-stacks.callstack-show",
        "title": "Parallel Stacks: Show",
		"icon": "$(symbol-class)"
      }
    ],
	"menus": {
		"view/title":[
			{
				"command": "parallel-stacks.callstack-show",
				"when": "view == workbench.debug.callStackView",
				"group": "navigation"
			}
		]
	}
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.105.0",
	"@types/vscode-webview": "^1.57.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.46.3",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}